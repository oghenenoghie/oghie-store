{
  "$schema": "https://railway.app/railway-schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "startCommand": "gunicorn oghie.wsgi --chdir oghie --workers 2 --bind 0.0.0.0:$PORT --log-file -",
    "releaseCommand": "python oghie/manage.py migrate --noinput && python oghie/manage.py collectstatic --noinput",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
