{
  "buildCommand": "pip install -r requirements.txt && python manage.py migrate --no-input",
  "builds": [
    {
      "src": "oghie/wsgi.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "15mb",
        "runtime": "python3.12"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "oghie/wsgi.py"
    }
  ]
}
